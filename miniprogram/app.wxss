/**
 * 全局样式
 */
page {
  background-color: #f5f5f5;
  font-size: 28rpx;
  color: #333;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

/* 通用卡片 */
.card {
  background: #fff;
  border-radius: 16rpx;
  margin: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

/* 列表项 */
.list-item {
  background: #fff;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.list-item:last-child {
  border-bottom: none;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.tag-warning {
  background: #fff7e6;
  color: #fa8c16;
}

.tag-success {
  background: #f6ffed;
  color: #52c41a;
}

.tag-danger {
  background: #fff2f0;
  color: #ff4d4f;
}

.tag-info {
  background: #e6f7ff;
  color: #1890ff;
}

/* 按钮 */
.btn {
  display: inline-block;
  padding: 16rpx 40rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  text-align: center;
}

.btn-primary {
  background: #1890ff;
  color: #fff;
}

.btn-success {
  background: #52c41a;
  color: #fff;
}

.btn-danger {
  background: #ff4d4f;
  color: #fff;
}

.btn-default {
  background: #f5f5f5;
  color: #666;
}

/* 金额 */
.amount {
  color: #ff4d4f;
  font-weight: bold;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 26rpx;
}

/* 表单 */
.form-item {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #eee;
}

.form-label {
  width: 180rpx;
  color: #666;
}

.form-value {
  flex: 1;
  text-align: right;
}

/* 描述列表 */
.desc-item {
  display: flex;
  padding: 20rpx 0;
}

.desc-label {
  width: 180rpx;
  color: #999;
}

.desc-value {
  flex: 1;
}
