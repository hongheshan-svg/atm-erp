<!--首页 - 工作台-->
<view class="container">
  <!-- 用户信息 -->
  <view class="header">
    <view class="user-info">
      <view class="avatar">{{userInfo.username[0] || 'U'}}</view>
      <view class="user-detail">
        <text class="name">{{userInfo.first_name || userInfo.username}}</text>
        <text class="dept">{{userInfo.department_name || '未设置部门'}}</text>
      </view>
    </view>
    <view class="date">{{today}}</view>
  </view>

  <!-- 待办统计 -->
  <view class="stats-card">
    <view class="stat-item" bindtap="goToApproval">
      <text class="stat-num">{{pendingCount}}</text>
      <text class="stat-label">待审批</text>
    </view>
    <view class="stat-item" bindtap="goToMySubmit">
      <text class="stat-num">{{submittedCount}}</text>
      <text class="stat-label">我提交的</text>
    </view>
    <view class="stat-item" bindtap="goToProject">
      <text class="stat-num">{{projectCount}}</text>
      <text class="stat-label">进行中项目</text>
    </view>
  </view>

  <!-- 快捷入口 -->
  <view class="card">
    <view class="card-title">快捷入口</view>
    <view class="quick-entry">
      <view class="entry-item" bindtap="goToApproval">
        <text class="entry-icon">📋</text>
        <text class="entry-text">待办审批</text>
      </view>
      <view class="entry-item" bindtap="goToProject">
        <text class="entry-icon">📁</text>
        <text class="entry-text">项目列表</text>
      </view>
      <view class="entry-item" bindtap="goToDashboard">
        <text class="entry-icon">📊</text>
        <text class="entry-text">数据看板</text>
      </view>
      <view class="entry-item" bindtap="goToMySubmit">
        <text class="entry-icon">📝</text>
        <text class="entry-text">我的提交</text>
      </view>
    </view>
  </view>

  <!-- 待办事项 -->
  <view class="card">
    <view class="card-header">
      <text class="card-title">待办事项</text>
      <text class="card-more" bindtap="goToApproval">查看全部 ></text>
    </view>
    
    <view wx:if="{{pendingTasks.length === 0}}" class="empty">
      <text>暂无待办事项 🎉</text>
    </view>
    
    <view wx:for="{{pendingTasks}}" wx:key="id" class="todo-item" bindtap="goToDetail" data-id="{{item.id}}">
      <view class="todo-header">
        <text class="todo-type tag tag-info">{{item.business_type_display}}</text>
        <text class="todo-time">{{item.created_at_display}}</text>
      </view>
      <view class="todo-content">
        <text class="todo-no">{{item.business_no}}</text>
        <text class="todo-amount amount">¥{{item.amount_display}}</text>
      </view>
      <view class="todo-footer">
        <text class="todo-submitter">提交人: {{item.submitter_name}}</text>
        <text class="todo-step">{{item.step_name}}</text>
      </view>
    </view>
  </view>
</view>
