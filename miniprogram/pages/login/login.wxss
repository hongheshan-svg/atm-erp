/**
 * 登录页面样式
 */
.login-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  padding: 100rpx 60rpx;
  box-sizing: border-box;
}

.logo-section {
  text-align: center;
  margin-bottom: 80rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 30rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  color: #fff;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.form-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.1);
}

.input-group {
  display: flex;
  align-items: center;
  border-bottom: 2rpx solid #eee;
  padding: 20rpx 0;
  margin-bottom: 30rpx;
}

.input-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.input {
  flex: 1;
  font-size: 32rpx;
  height: 80rpx;
}

.toggle-pwd {
  font-size: 40rpx;
  padding: 10rpx;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #fff;
  font-size: 34rpx;
  border-radius: 48rpx;
  margin-top: 40rpx;
  border: none;
}

.login-btn[loading] {
  opacity: 0.7;
}

.tips {
  text-align: center;
  margin-top: 40rpx;
  color: #999;
  font-size: 26rpx;
}
