/**
 * 项目详情样式
 */
.project-header {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  padding: 40rpx 30rpx;
  color: #fff;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.project-code {
  font-size: 26rpx;
  opacity: 0.9;
}

.project-status {
  background: rgba(255, 255, 255, 0.2) !important;
  color: #fff !important;
}

.project-name {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.project-date {
  font-size: 26rpx;
  opacity: 0.8;
}

/* 统计卡片 */
.stats-card {
  display: flex;
  background: #fff;
  margin: -30rpx 20rpx 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  position: relative;
  z-index: 10;
}

.stat-item {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  border-right: 1rpx solid #eee;
}

.stat-item:last-child {
  border-right: none;
}

.stat-num {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #1890ff;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

/* 信息列表 */
.info-list {
  margin-top: 20rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  color: #999;
}

.info-value {
  color: #333;
  font-weight: 500;
}

/* 预算使用 */
.budget-item {
  margin-bottom: 30rpx;
}

.budget-item:last-child {
  margin-bottom: 0;
}

.budget-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
  font-size: 26rpx;
}

.budget-name {
  color: #666;
}

.budget-amount {
  color: #333;
}

.progress-bar {
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.3s;
}

/* 任务进度 */
.task-progress {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
}

.progress-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: conic-gradient(#52c41a 0%, #52c41a var(--progress, 0%), #f0f0f0 var(--progress, 0%));
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 40rpx;
  position: relative;
}

.progress-circle::before {
  content: '';
  position: absolute;
  width: 120rpx;
  height: 120rpx;
  background: #fff;
  border-radius: 50%;
}

.progress-value {
  position: relative;
  z-index: 1;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.progress-detail {
  flex: 1;
}

.detail-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  color: #666;
}

.detail-item:last-child {
  margin-bottom: 0;
}

.detail-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.detail-dot.todo {
  background: #d9d9d9;
}

.detail-dot.doing {
  background: #1890ff;
}

.detail-dot.done {
  background: #52c41a;
}

/* 描述 */
.description {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}
