/**
 * 审批详情样式
 */
.container {
  padding-bottom: 200rpx;
}

/* 状态头部 */
.status-header {
  padding: 60rpx 30rpx;
  text-align: center;
  color: #fff;
}

.status-header.pending {
  background: linear-gradient(135deg, #faad14 0%, #d48806 100%);
}

.status-header.approved {
  background: linear-gradient(135deg, #52c41a 0%, #389e0d 100%);
}

.status-header.rejected {
  background: linear-gradient(135deg, #ff4d4f 0%, #cf1322 100%);
}

.status-header.withdrawn {
  background: linear-gradient(135deg, #8c8c8c 0%, #595959 100%);
}

.status-icon {
  display: block;
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.status-text {
  font-size: 36rpx;
  font-weight: bold;
}

/* 信息列表 */
.info-list {
  margin-top: 20rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  color: #999;
}

.info-value {
  color: #333;
  font-weight: 500;
}

.info-value.highlight {
  color: #1890ff;
}

/* 时间线 */
.timeline {
  margin-top: 20rpx;
  padding-left: 30rpx;
}

.timeline-item {
  position: relative;
  padding-left: 40rpx;
  padding-bottom: 40rpx;
  border-left: 2rpx solid #e8e8e8;
}

.timeline-item:last-child {
  border-left: none;
  padding-bottom: 0;
}

.timeline-dot {
  position: absolute;
  left: -12rpx;
  top: 0;
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #e8e8e8;
}

.timeline-dot.done {
  background: #52c41a;
}

.timeline-dot.rejected {
  background: #ff4d4f;
}

.timeline-dot.current {
  background: #1890ff;
  box-shadow: 0 0 0 6rpx rgba(24, 144, 255, 0.2);
}

.timeline-content {
  background: #fafafa;
  padding: 20rpx;
  border-radius: 8rpx;
}

.timeline-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.timeline-title {
  font-weight: bold;
  color: #333;
}

.timeline-body {
  font-size: 26rpx;
  color: #666;
}

.timeline-body text {
  display: block;
  margin-bottom: 8rpx;
}

.timeline-comment {
  color: #1890ff;
  background: #e6f7ff;
  padding: 10rpx 16rpx;
  border-radius: 8rpx;
  margin-top: 10rpx;
}

/* 操作区域 */
.action-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.comment-input {
  margin-bottom: 20rpx;
}

.textarea {
  width: 100%;
  height: 120rpx;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
}

.action-buttons .btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  border: none;
}

.full-width {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
}
