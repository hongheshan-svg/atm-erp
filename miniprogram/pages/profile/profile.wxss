/**
 * 个人中心样式
 */
.user-card {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  padding: 60rpx 30rpx;
  display: flex;
  align-items: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  color: #fff;
  font-size: 48rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 30rpx;
}

.user-info {
  display: flex;
  flex-direction: column;
}

.name {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 10rpx;
}

.position {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 6rpx;
}

.dept {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 工作统计 */
.work-stats {
  display: flex;
  margin-top: 20rpx;
}

.work-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
}

.work-num {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #1890ff;
}

.work-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

/* 菜单 */
.menu-card {
  padding: 0 !important;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.menu-arrow {
  color: #ccc;
  font-size: 28rpx;
}

/* 退出登录 */
.logout-section {
  padding: 40rpx 20rpx;
}

.logout-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #fff;
  color: #ff4d4f;
  font-size: 32rpx;
  border-radius: 44rpx;
  border: 2rpx solid #ff4d4f;
}

/* 版本信息 */
.version {
  text-align: center;
  padding: 40rpx 0;
  color: #ccc;
  font-size: 24rpx;
}
