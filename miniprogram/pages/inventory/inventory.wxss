.container { padding: 20rpx; background: #f5f5f5; min-height: 100vh; }
.search-bar { display: flex; gap: 16rpx; margin-bottom: 20rpx; background: #fff; padding: 16rpx; border-radius: 12rpx; }
.search-bar input { flex: 1; border: 1rpx solid #ddd; border-radius: 8rpx; padding: 12rpx 16rpx; }
.search-bar button { background: #409eff; color: #fff; }
.stock-item { background: #fff; border-radius: 12rpx; padding: 20rpx; margin-bottom: 16rpx; }
.stock-main { margin-bottom: 12rpx; }
.stock-code { font-size: 30rpx; font-weight: bold; color: #409eff; margin-right: 16rpx; }
.stock-name { font-size: 28rpx; color: #333; }
.stock-detail { display: flex; flex-wrap: wrap; gap: 16rpx; }
.stock-info { font-size: 26rpx; }
.info-label { color: #999; margin-right: 8rpx; }
.info-value { color: #333; }
.info-value.danger { color: #f56c6c; font-weight: bold; }
.stock-warning { margin-top: 12rpx; padding: 8rpx 16rpx; background: #fef0f0; border-radius: 6rpx; }
.warning-text { font-size: 24rpx; color: #f56c6c; }
.empty, .loading-tip, .no-more { text-align: center; color: #999; padding: 40rpx; font-size: 28rpx; }
