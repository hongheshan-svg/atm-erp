# ERP系统环境变量配置模板
# 复制此文件为 .env 并根据实际环境修改配置

# Django配置
SECRET_KEY=django-insecure-PLEASE-CHANGE-THIS-TO-RANDOM-STRING
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# 数据库配置
DB_NAME=erp_db
DB_USER=erp_user
DB_PASSWORD=PLEASE-CHANGE-THIS-STRONG-PASSWORD
DB_HOST=postgres
DB_PORT=5432

# Redis配置
REDIS_HOST=redis
REDIS_URL=redis://redis:6379/1

# Celery配置
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Elasticsearch配置
ELASTICSEARCH_HOST=elasticsearch:9200

# CORS配置
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:8080
CSRF_TRUSTED_ORIGINS=http://localhost,http://localhost:8080

# 前端URL
FRONTEND_URL=http://localhost:8080

# JWT配置
JWT_ACCESS_LIFETIME_MINUTES=120
JWT_REFRESH_LIFETIME_DAYS=7

# HTTPS配置（生产环境启用）
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# ===========================================
# Docker 镜像（一键安装）
# ===========================================
# 镜像仓库与所有者（默认 GHCR 官方包）
REGISTRY=ghcr.io
IMAGE_OWNER=hongheshan-svg
# 镜像版本标签（如 0.2.0；latest 为最新）
IMAGE_TAG=latest

# 宿主机端口（如 80/443 被占用可改）
HTTP_PORT=80
HTTPS_PORT=443

# ===========================================
# 初始管理员（首次启动自动创建）
# ===========================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
# 是否灌入示例数据：0=否 1=是
SEED_DEMO_DATA=0
