# Production Environment Configuration
# Copy this file to .env.prod and configure all values

# =============================================================================
# SECURITY - MUST CHANGE IN PRODUCTION
# =============================================================================

# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-super-secret-key-change-this-in-production

# MUST be False in production
DEBUG=False

# Your domain(s), comma-separated
ALLOWED_HOSTS=your-domain.com,www.your-domain.com

# CSRF trusted origins (include https://)
CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# CORS allowed origins
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# =============================================================================
# DATABASE
# =============================================================================

DB_NAME=erp_db
DB_USER=erp_user
DB_PASSWORD=your-strong-database-password
DB_HOST=db
DB_PORT=5432

# =============================================================================
# REDIS
# =============================================================================

REDIS_HOST=redis
REDIS_URL=redis://redis:6379/1
REDIS_PASSWORD=your-redis-password

# Celery
CELERY_BROKER_URL=redis://:your-redis-password@redis:6379/0
CELERY_RESULT_BACKEND=redis://:your-redis-password@redis:6379/0

# =============================================================================
# ELASTICSEARCH
# =============================================================================

ELASTICSEARCH_HOST=elasticsearch:9200

# =============================================================================
# HTTPS / SSL SETTINGS
# =============================================================================

SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# =============================================================================
# JWT SETTINGS
# =============================================================================
# settings.py 优先读取下面这两个变量名（也向后兼容旧名
# JWT_ACCESS_LIFETIME_MINUTES / JWT_REFRESH_LIFETIME_DAYS）。
# 生产建议短一些的访问令牌有效期（默认回退值为 120 分钟 / 7 天）。

JWT_ACCESS_TOKEN_LIFETIME_MINUTES=30
JWT_REFRESH_TOKEN_LIFETIME_DAYS=1

# =============================================================================
# PASSWORD POLICY
# =============================================================================

PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=True
PASSWORD_REQUIRE_LOWERCASE=True
PASSWORD_REQUIRE_DIGIT=True
PASSWORD_REQUIRE_SPECIAL=True
PASSWORD_EXPIRY_DAYS=90
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30

# =============================================================================
# EMAIL SETTINGS
# =============================================================================

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.your-email-provider.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@domain.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=ERP System <noreply@your-domain.com>

# =============================================================================
# NOTIFICATION INTEGRATIONS (Optional)
# =============================================================================

# DingTalk
DINGTALK_WEBHOOK_URL=
DINGTALK_WEBHOOK_SECRET=

# WeChat Work
WECHAT_WORK_WEBHOOK_URL=

# =============================================================================
# FRONTEND URL
# =============================================================================

FRONTEND_URL=https://your-domain.com

# =============================================================================
# INVENTORY SETTINGS
# =============================================================================

INVENTORY_COSTING_METHOD=FIFO

# =============================================================================
# BACKUP ENCRYPTION
# =============================================================================
# 数据库备份加密密钥（Fernet key）。留空则备份仅 gzip（明文）。
# 生产强烈建议设置，使备份落盘即为加密文件（.sql.gz.enc）。
# 生成方式：
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BACKUP_ENCRYPTION_KEY=
