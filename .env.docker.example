# ERP System Docker Environment Configuration
# Copy this file to .env and modify values as needed

# ===========================================
# Django Settings
# ===========================================
DEBUG=
SECRET_KEY=

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=

# ===========================================
# Database Configuration
# ===========================================
DB_NAME=
DB_USER=
DB_PASSWORD=

# ===========================================
# CORS & CSRF Settings
# ===========================================
CORS_ALLOWED_ORIGINS=
CSRF_TRUSTED_ORIGINS=

# ===========================================
# Frontend URL (for email links, etc.)
# ===========================================
FRONTEND_URL=

# ===========================================
# JWT Token Settings
# ===========================================
JWT_ACCESS_LIFETIME_MINUTES=
JWT_REFRESH_LIFETIME_DAYS=

# ===========================================
# Security Settings (Production)
# ===========================================
SECURE_SSL_REDIRECT=
SECURE_HSTS_SECONDS=
SESSION_COOKIE_SECURE=
CSRF_COOKIE_SECURE=

# ===========================================
# Notification Settings (Optional)
# ===========================================
# DingTalk
DINGTALK_WEBHOOK_URL=
DINGTALK_WEBHOOK_SECRET=
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_AGENT_ID=

# WeChat Work
WECHAT_WORK_WEBHOOK_URL=
WECHAT_WORK_CORP_ID=
WECHAT_WORK_CORP_SECRET=
WECHAT_WORK_AGENT_ID=

# Feishu / Lark (飞书)
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Enabled notification channels (comma-separated)
NOTIFICATION_CHANNELS_ENABLED=

# ===========================================
# 企业 IM 扫码登录 (OAuth) — 企业微信/钉钉/飞书
# ===========================================
# 复用上方 WECHAT_WORK_CORP_ID/SECRET/AGENT_ID、DINGTALK_APP_KEY/SECRET、FEISHU_APP_ID/SECRET。
# 首登自动建号开关(组织成员扫码即建号,默认 employee 最小权限):
OAUTH_AUTO_CREATE=true
# 新建用户是否直接激活(false=需管理员激活):
OAUTH_NEW_USER_ACTIVE=true
# 是否允许扫码时按手机号自动绑定到「已存在」的 ERP 账号(默认 false,更安全:
# 既有账号需管理员一次性绑定其 IM ID;开 true 则信任 IM 核验手机号,非特权既有账号可自动绑定):
OAUTH_BIND_EXISTING_BY_PHONE=false
# 可选:仅允许这些邮箱域名自动建号(逗号分隔,空=不限):
OAUTH_ALLOWED_EMAIL_DOMAINS=
# 前端回调域名(扫码 redirect_uri 用,需在各平台后台配可信域):
FRONTEND_URL=

# ===========================================
# Inventory Settings
# ===========================================
# Options: WEIGHTED_AVG, FIFO
INVENTORY_COSTING_METHOD=

# ===========================================
# Password Policy
# ===========================================
PASSWORD_MIN_LENGTH=
PASSWORD_REQUIRE_UPPERCASE=
PASSWORD_REQUIRE_LOWERCASE=
PASSWORD_REQUIRE_DIGIT=
PASSWORD_REQUIRE_SPECIAL=
PASSWORD_EXPIRY_DAYS=

# ===========================================
# Login Security
# ===========================================
MAX_LOGIN_ATTEMPTS=
LOCKOUT_DURATION_MINUTES=
